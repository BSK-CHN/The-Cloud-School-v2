# ============================================================================
# The Cloud School — environment variables
# Copy to `.env` for local dev (Bun auto-loads it into process.env).
# In production (Vercel) set these in the project dashboard. They are also
# declared in vite.config.ts (nitro.vercel.functions.env) so the serverless
# function receives them at runtime.
#
# RULE: server secrets must NOT be prefixed with VITE_ (that would leak
# them into the browser). Only client-safe values use the VITE_ prefix.
# ============================================================================

# ---- Server (secret) ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=The Cloud School <onboarding@resend.dev>
ADMIN_EMAIL=admin@thecloudschool.in
SITE_URL=https://thecloudschool.in
WHATSAPP_NUMBER=919840991965

# ---- Client (VITE_ prefix → inlined into the browser bundle) ----
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
VITE_SITE_URL=https://thecloudschool.in
VITE_GA4_ID=G-XXXXXXX
VITE_GSC_ID=your-google-search-console-verification-code
VITE_WHATSAPP_NUMBER=919840991965

# ---- Abuse protection (Cloudflare Turnstile) — see launch summary ----
# Server secret: required ONLY when you want to enforce bot challenges in production.
# Leave UNSET to disable Turnstile (e.g. local dev). Generate at
# dash.cloudflare.com → Turnstile → create a site; use its "Secret key".
TURNSTILE_SECRET_KEY=
# Client site key: from the same Turnstile widget. Inlined to the browser
# only when set; when empty the client widget is a no-op and forms work unchanged.
VITE_TURNSTILE_SITE_KEY=
