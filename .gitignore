# ============================================================================
# The Cloud School — production .gitignore
# (Bun + Vite + TanStack Start + Nitro/Vercel)
# ============================================================================

# ---- Dependencies ----
node_modules
node_modules/.cache

# ---- Build / deploy outputs ----
.output
.vercel
.wrangler
.tanstack
dist
build

# ---- Logs ----
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-debug.log*
.pnpm-debug.log*

# ---- Caches ----
.cache
caches
*.tsbuildinfo

# ---- Local environment / secrets (NEVER commit real secrets) ----
.env
.env.*
!.env.example

# ---- OS / editor ----
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/*
!.vscode/extensions.json

# ---- Misc ----
*.local
